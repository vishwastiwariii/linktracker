
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PRO
}


enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  BOT
}


model User {
  id String @id @default(cuid())
  clerkUserId String @unique
  email String @unique
  name String
  plan Plan @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  links Link[]
}


model Link {
  id String @id @default(cuid())
  userId String
  name String
  url String
  originalUrl String
  slug String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [clerkUserId], onDelete: Cascade)
  clickEvents   ClickEvent[]

  @@index([userId])
}

model ClickEvent {
  id String @id @default(cuid())
  linkId String

  country String?
  city String?
  device DeviceType?
  browser String?
  ipHash   String?

  createdAt DateTime @default(now())

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, createdAt])
  @@index([createdAt])
}
  


